# GitHub App Configuration
# 从你的 GitHub App 设置中获取这些值

# 你的 GitHub 用户名
PUBLIC_GITHUB_OWNER=kobaridev

# 你的仓库名称
PUBLIC_GITHUB_REPO=RyuChan

# 你的仓库分支
PUBLIC_GITHUB_BRANCH=dev

# 你的 GitHub App ID（在 GitHub App -> General -> App ID 中查找）
# 注意：这个值必须填写，否则 Workers 部署的 GitHub 认证将无法工作
# 你可以从 Cloudflare Pages 的环境变量设置中找到你之前配置的值
PUBLIC_GITHUB_APP_ID=2409511

# 用于加密存储私钥的密钥
PUBLIC_GITHUB_ENCRYPT_KEY=wudishiduomejimo